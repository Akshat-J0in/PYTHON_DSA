str = "()(()())(())"
ans = []

count = 0

for ch in str:

    if ch == '(':
        if count > 0:
            ans.append(ch)
        count += 1

    else:
        count -= 1
        if count > 0:
            ans.append(ch)

print(''.join(ans))

